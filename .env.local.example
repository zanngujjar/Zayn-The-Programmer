# Base URL for the site (used for sitemaps and social sharing)
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Cache settings
CONTENT_CACHE_TTL=3600

# Revalidation secret for ISR
REVALIDATE_SECRET=your-secret-token

# Optional: Algolia settings for advanced search (if implemented later)
# ALGOLIA_APP_ID=your-app-id
# ALGOLIA_API_KEY=your-api-key

# Optional: Analytics
# GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
# VERCEL_ANALYTICS_ID=your-vercel-analytics-id

# Optional: CMS settings (for future headless CMS integration)
# CMS_API_URL=https://your-cms.com/api
# CMS_API_KEY=your-cms-api-key